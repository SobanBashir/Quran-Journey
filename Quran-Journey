    text-decoration: none;
    color: black;
}


/* NAVBAR TOGGLE */
.menu-toggle {
    display: none;
    font-size: 24px;
    cursor: pointer;
}

/* BUTTON BASE */
.btn, button {
    background: #f5b800;
    border: none;
    padding: 10px 20px;
    border-radius: 25px;
    cursor: pointer;
    transition: all 0.3s ease;
}

/* HOVER EFFECT */
.btn:hover, button:hover {
    background: #d49f00;
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.2);
}

/* CLICK EFFECT */
.btn:active, button:active {
    transform: scale(0.95);
}

.btn::after {
    content: "";
    position: absolute;
    width: 0%;
    height: 100%;
    background: rgba(255,255,255,0.2);
    left: 0;
    top: 0;
    transition: 0.3s;
    border-radius: 25px;
}

.btn:hover::after {
    width: 100%;
}



